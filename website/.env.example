# Postgres connection
DATABASE_URL=postgresql://postgres:abcd@localhost:5432/swayat

# WhatsApp bot phone number (digits only)
BOT_PHONE_NUMBER=15551234567

# Square payments
SQUARE_ACCESS_TOKEN=your-square-access-token
NEXT_PUBLIC_SQUARE_APP_ID=your-square-app-id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your-square-location-id
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key

# Public base URL (for webhook signature verification)
NEXT_PUBLIC_BASE_URL=https://swayat.com

# Bot internal API
BOT_API_URL=https://api.swayat.com
