# Postgres connection
DATABASE_URL=postgresql://postgres:abcd@localhost:5432/swayat

# WhatsApp bot phone number (digits only)
BOT_PHONE_NUMBER=15551234567

# Square payments
SQUARE_ACCESS_TOKEN=your-square-access-token
NEXT_PUBLIC_SQUARE_APP_ID=your-square-app-id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your-square-location-id
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key

# Public base URL (for webhook signature verification)
NEXT_PUBLIC_BASE_URL=https://swayat.com

# Bot internal API
BOT_API_URL=https://api.swayat.com

# Resend email
RESEND_API_KEY=re_your-resend-key

# HMAC secret for one-click unsubscribe link signing
UNSUBSCRIBE_SECRET=change-me-to-a-long-random-string

# Admin token for /api/resend-welcome and other admin endpoints
ADMIN_TOKEN=change-me-to-a-long-random-string

# Google Calendar Appointment Schedule embed URL for /book-demo
# Get this from Google Calendar → Appointment Schedule → Share → Embed → src=...
NEXT_PUBLIC_DEMO_BOOKING_URL=

# Shared secret for authenticated calls to the bot API (must match bot .env SERVICE_API_SECRET)
SERVICE_API_SECRET=your-service-api-secret-here

# Admin dashboard (admin.swayat.com) login password
ADMIN_PASSWORD=change-me-to-a-strong-password
